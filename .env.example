# App Settings
APP_NAME=My FastAPI App
APP_URL=http://localhost:8000
PROJECT_VERSION=1.0.0
DEBUG=true
ALLOWED_ORIGINS=*
# Or for prod: ALLOWED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com
ENVIRONMENT=production
# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
# DATABASE_URL=postgresql+asyncpg://postgres:1234@localhost:5433/fastapi_skeleton_dev
# For SQLite: DATABASE_URL=sqlite+aiosqlite:///db.sqlite

# Rate Limiting
RATE_LIMIT_ENABLED=false  # Set to true to enable SlowAPI (requires Redis)

# Cache (default: in-memory, set to redis for Redis)
CACHE_TYPE=inmemory  # inmemory, redis, or database
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-secret-key  # Run python generate_secret.py to generate
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment & Token Settings
ENVIRONMENT=development  # development, test, staging, production
REFRESH_TOKEN_EXPIRE_DAYS=30

# File Upload Settings
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# Email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email
EMAIL_PASSWORD=your-password
EMAIL_FROM=your-email@example.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False  # True for port 465
TEMPLATE_FOLDER=templates/emails  # Relative path to Jinja2 templates
SUPPRESS_SEND=0  # 1 for testing (mocks sending)

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=logs